# LOCAL DEVELOPMENT ONLY — never commit a real .env file.
# In production, ALL of these are resolved from Azure Key Vault via Managed Identity.

ENVIRONMENT=development
AZURE_KEY_VAULT_URL=
JWT_SECRET_KEY=replace-with-a-long-random-string-for-local-testing-only
ACCESS_TOKEN_EXPIRE_MINUTES=15
ALLOWED_ORIGINS=["http://localhost:3000"]
RATE_LIMIT=30/minute
MODEL_PATH=app/models/artifacts/fraud_model.joblib
